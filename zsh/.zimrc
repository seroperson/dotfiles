#!/bin/zsh

# lazy sourcing
zmodule romkatv/zsh-defer
# change directory to git root
zmodule mollifier/cd-gitroot --fpath . --autoload cd-gitroot

# minimal's dependencies
zmodule zimfw/prompt-pwd
zmodule zimfw/git-info
# the best theme ever
zmodule zimfw/minimal

# jumping around (alternative to fasd)
zmodule rupa/z --source z.sh
# zsh anything.el-like widget
# `--cmd` skips zimfw's auto-source; we defer-source it from .zshrc
zmodule zsh-users/zaw --cmd ':'
# faster git + zsh
zmodule ohmyzsh/ohmyzsh --root plugins/gitfast

# automatically starts ssh-agent
zmodule ohmyzsh/ohmyzsh --root plugins/ssh-agent

# automatically activate python venv
zmodule MichaelAquilina/zsh-autoswitch-virtualenv

# history-based autosuggestions
zmodule zsh-users/zsh-autosuggestions

# missing completions (must be before autocomplete)
zmodule zsh-users/zsh-completions
zmodule carlosedp/mill-zsh-completions
# zmodule ohmyzsh/ohmyzsh --root plugins/gh

# autocomplete
zmodule marlonrichert/zsh-autocomplete
